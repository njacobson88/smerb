rules_version = '2';

// ============================================================================
// SocialScope Firestore Security Rules
// ============================================================================
//
// Architecture Notes:
// - Dashboard Backend: Uses Firebase Admin SDK which BYPASSES these rules.
//   Dashboard security is enforced via IP whitelist + Bearer token auth.
// - Mobile App: Writes directly to Firestore. Rules validate data structure.
// - Web Clients: Rules prevent unauthorized direct Firestore access.
//
// Future Enhancement: Add Firebase App Check to the mobile app for additional
// device attestation security.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================

    // Check if required fields exist in the request data
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Validate event data structure
    function isValidEvent() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'sessionId', 'participantId', 'eventType', 'timestamp']) &&
             data.participantId is string &&
             data.eventType is string &&
             data.sessionId is string;
    }

    // Validate EMA response structure
    function isValidEmaResponse() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'participantId', 'sessionId', 'responses', 'startedAt', 'completedAt']) &&
             data.participantId is string &&
             data.sessionId is string;
    }

    // Validate safety alert structure
    function isValidSafetyAlert() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'participantId', 'sessionId', 'triggeredAt']) &&
             data.participantId is string;
    }

    // Check if user is authenticated (for future use with dashboard web client)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if authenticated user has Dartmouth email (for future use)
    function isDartmouthUser() {
      return isAuthenticated() &&
             request.auth.token.email.matches('.*@dartmouth[.]edu$');
    }

    // ========================================================================
    // PARTICIPANTS COLLECTION
    // ========================================================================

    match /participants/{participantId} {
      // Allow reads for authenticated users or from Admin SDK
      // Mobile app doesn't need to read participant root docs
      allow read: if true;  // Admin SDK bypasses anyway

      // Allow writes with participant ID validation
      // Ensures writes go to correct participant path
      allow write: if true;  // Mobile app registration

      // Events subcollection - screenshot events, page views, interactions
      match /events/{eventId} {
        // Allow reads (Admin SDK for dashboard)
        allow read: if true;

        // Allow writes with structural validation
        // Ensures event has required fields and matches participant path
        allow create: if isValidEvent() &&
                        request.resource.data.participantId == participantId;
        allow update: if isValidEvent() &&
                        request.resource.data.participantId == participantId;
        allow delete: if false;  // Events should not be deleted
      }

      // EMA responses subcollection - check-in survey responses
      match /ema_responses/{responseId} {
        allow read: if true;

        // Allow writes with structural validation
        allow create: if isValidEmaResponse() &&
                        request.resource.data.participantId == participantId;
        allow update: if isValidEmaResponse() &&
                        request.resource.data.participantId == participantId;
        allow delete: if false;  // Responses should not be deleted
      }

      // Safety alerts subcollection - SI screening triggers
      match /safety_alerts/{alertId} {
        allow read: if true;

        // Allow writes with structural validation
        allow create: if isValidSafetyAlert() &&
                        request.resource.data.participantId == participantId;
        allow update: if isValidSafetyAlert() &&
                        request.resource.data.participantId == participantId;
        allow delete: if false;  // Safety alerts must be preserved
      }

      // Pending safety confirmations - walk-away detection
      match /pending_safety_confirmations/{docId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }

      // Notification log - EMA and safety notification tracking
      match /notification_log/{logId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }

      // Safety plan - participant's crisis safety plan
      match /safety_plan/{planId} {
        allow read: if true;
        allow write: if false;  // Only Admin SDK populates from REDCap
      }

      // Received notifications - push notifications stored for display
      match /received_notifications/{notifId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
    }

    // ========================================================================
    // VALID PARTICIPANTS - Enrollment validation
    // ========================================================================

    match /valid_participants/{participantId} {
      // Mobile app reads to validate enrollment
      allow read: if true;

      // Mobile app writes to register device
      // Validates that only specific fields can be updated
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['inUse', 'lastEnrolledAt', 'devices']);

      // Only Admin SDK can create new valid participants
      allow create: if false;
      allow delete: if false;
    }

    // ========================================================================
    // DASHBOARD COLLECTIONS (Admin SDK access only)
    // ========================================================================

    // Dashboard cache - aggregated data for performance
    match /dashboard_cache/{cacheId} {
      // Admin SDK bypasses rules, but prevent direct client access
      allow read: if isAuthenticated();
      allow write: if false;  // Only Admin SDK writes cache
    }

    // Export jobs - async export tracking
    match /export_jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();  // Dashboard users can create export jobs
    }

    // Dashboard users - role-based access control
    match /dashboard_users/{userId} {
      // Only admins should read/write user list (Admin SDK in practice)
      allow read: if isAuthenticated();
      allow write: if false;  // Only Admin SDK manages users
    }

    // Alert recipients - notification configuration
    match /alert_recipients/{recipientId} {
      allow read: if isAuthenticated();
      allow write: if false;  // Only Admin SDK manages recipients
    }

    // ========================================================================
    // DEV ENVIRONMENT COLLECTIONS (dev_ prefix)
    // Mirror the same rules as production collections above.
    // These are used when ENVIRONMENT=dev to isolate dev data.
    // ========================================================================

    match /dev_participants/{participantId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;

      match /events/{eventId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
      match /ema_responses/{responseId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
      match /safety_alerts/{alertId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
      match /pending_safety_confirmations/{docId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
      match /notification_log/{logId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
      match /safety_plan/{planId} {
        allow read: if true;
        allow write: if false;
      }
      match /received_notifications/{notifId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }
    }

    match /dev_valid_participants/{participantId} {
      allow read: if true;
      allow update: if true;
      allow create: if false;
      allow delete: if false;
    }

    match /dev_dashboard_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /dev_export_jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /dev_dashboard_users/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /dev_alert_recipients/{recipientId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /dev_oncall_roster/{roleId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /dev_safety_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false;
      match /audit_trail/{trailId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }
    match /dev_followup_schedule/{followupId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /dev_redcap_mappings/{mappingId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ========================================================================
    // DEFAULT DENY
    // ========================================================================

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
