# SocialScope Dashboard Backend Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# Required in Production
# =============================================================================

# Firebase project ID - must match your Firebase Console project
FIREBASE_PROJECT_ID=r01-redditx-suicide

# Secret token for Cloud Scheduler authentication
# Generate a secure random string for production
SCHEDULER_SECRET=your-secure-secret-here

# =============================================================================
# Optional - Server Configuration
# =============================================================================

# Server bind address (default: 0.0.0.0)
# DASHBOARD_HOST=0.0.0.0

# Server port (default: 8080)
# DASHBOARD_PORT=8080

# =============================================================================
# Optional - Study Configuration
# =============================================================================

# Study start date for compliance calculations (default: 2025-01-01)
# STUDY_START_DATE=2025-01-01

# Expected EMA check-ins per day for compliance % (default: 3)
# EMA_PROMPTS_PER_DAY=3

# =============================================================================
# Optional - Security / Development
# =============================================================================

# Set to "true" to bypass IP whitelist (LOCAL DEVELOPMENT ONLY!)
# WARNING: Never enable in production
# DASHBOARD_DEV_MODE=false

# Comma-separated list of allowed CORS origins
# Defaults to localhost + Firebase Hosting URLs
# CORS_ORIGINS=http://localhost:3000,https://your-app.web.app

# =============================================================================
# Optional - File Storage
# =============================================================================

# Directory for temporary export files (default: /tmp/socialscope_exports)
# EXPORT_DIR=/tmp/socialscope_exports

# Path to Firebase service account JSON (optional on Cloud Run)
# Cloud Run provides default credentials automatically
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
